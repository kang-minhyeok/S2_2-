<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ================= 필수 기입 ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="필수 기입"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="아이디" />

            <EditText
                android:id="@+id/etId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="아이디 입력"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="비밀번호 입력"
                android:inputType="textPassword" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호 확인" />

            <EditText
                android:id="@+id/etPasswordCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="비밀번호 확인"
                android:inputType="textPassword" />
        </LinearLayout>

        <!-- 여백 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- ================= 선택 기입 ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="선택 기입"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기관 번호" />

            <EditText
                android:id="@+id/etSignupOrgCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="기관 번호 입력 (선택)"
                android:inputType="number" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이름" />

            <EditText
                android:id="@+id/etSignupName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="이름 입력" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전화번호" />

            <EditText
                android:id="@+id/etSignupPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="전화번호 입력"
                android:inputType="phone" />

            <!-- 주민등록번호 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="주민등록번호 (선택)"
                android:textSize="14sp"
                android:layout_marginTop="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 앞자리 -->
                <EditText
                    android:id="@+id/etResidentFront"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="앞 6자리"
                    android:inputType="number"
                    android:maxLength="6"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" - "
                    android:textSize="18sp"
                    android:paddingHorizontal="6dp"/>

                <!-- 뒷자리 (비밀번호) -->
                <EditText
                    android:id="@+id/etResidentBack"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="뒤 7자리"
                    android:inputType="numberPassword"
                    android:maxLength="7"/>
            </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="혈액형" />

            <EditText
                android:id="@+id/etSignupBlood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="혈액형 입력 (예: A형)" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="보유 질병" />

            <EditText
                android:id="@+id/etSignupDisease"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="보유 질병 입력" />
        </LinearLayout>

        <!-- 회원가입 버튼 -->
        <Button
            android:id="@+id/btnSignup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/black"
            android:text="회원가입"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>
